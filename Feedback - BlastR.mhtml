in: center top; will-change: transform, opacity, max-height, filter; filter=
: blur(0px); }

.message-item-pending { opacity: 0 !important; transform: translateY(-8px) =
!important; max-height: 0px !important; margin-top: 0px !important; margin-=
bottom: 0px !important; padding-top: 0px !important; padding-bottom: 0px !i=
mportant; overflow: hidden !important; pointer-events: none !important; fil=
ter: blur(4px) !important; }

.first-render .message-item { transition: none !important; }

@keyframes messageAppear {=20
  0% { opacity: 0; transform: translateY(-8px); filter: blur(4px); }
  100% { opacity: 1; transform: translateY(0px); filter: blur(0px); }
}

.message-item:not(.message-item-pending) { animation: 0.5s cubic-bezier(0.2=
, 0.8, 0.2, 1) 0s 1 normal forwards running messageAppear; }

.animate-appear { animation: 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0s 1 norma=
l forwards running messageAppear; }

.message-item p { word-break: break-word; overflow-wrap: break-word; hyphen=
s: auto; }

* { -webkit-font-smoothing: antialiased; }
