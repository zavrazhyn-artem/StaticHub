APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google Drive backup (set on production only — leave empty locally).
# When GOOGLE_DRIVE_REFRESH_TOKEN is set, Spatie backup ships DB dumps to Drive.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

VITE_APP_NAME="${APP_NAME}"

DISCORD_PUBLIC_KEY=

# Discord custom emoji IDs (override per-server; see config/discord_emojis.php for defaults)
DISCORD_EMOJI_CLASS_DEATH_KNIGHT=
DISCORD_EMOJI_CLASS_DEMON_HUNTER=
DISCORD_EMOJI_CLASS_DRUID=
DISCORD_EMOJI_CLASS_EVOKER=
DISCORD_EMOJI_CLASS_HUNTER=
DISCORD_EMOJI_CLASS_MAGE=
DISCORD_EMOJI_CLASS_MONK=
DISCORD_EMOJI_CLASS_PALADIN=
DISCORD_EMOJI_CLASS_PRIEST=
DISCORD_EMOJI_CLASS_ROGUE=
DISCORD_EMOJI_CLASS_SHAMAN=
DISCORD_EMOJI_CLASS_WARLOCK=
DISCORD_EMOJI_CLASS_WARRIOR=
DISCORD_EMOJI_ROLE_TANK=
DISCORD_EMOJI_ROLE_HEAL=
DISCORD_EMOJI_ROLE_MELEE=
DISCORD_EMOJI_ROLE_RANGE=
DISCORD_EMOJI_RSVP_PRESENT=
DISCORD_EMOJI_RSVP_LATE=
DISCORD_EMOJI_RSVP_TENTATIVE=
DISCORD_EMOJI_RSVP_ABSENT=
DISCORD_EMOJI_RSVP_PENDING=
DISCORD_EMOJI_RSVP_BENCH=

GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-3.1-flash-lite-preview
# Thinking level for Gemini 3+ models: low | medium | high (or empty to disable)
GEMINI_THINKING_LEVEL=high

ADMIN_ACCESS_KEY=
ADMIN_SUBDOMAIN=admin
# Optional: full admin hostname override. Use this instead of ADMIN_SUBDOMAIN
# when APP_URL itself is a subdomain and your wildcard cert only covers one
# level (e.g. *.blastr.pro covers admin-local.blastr.pro but not admin.local.blastr.pro).
ADMIN_DOMAIN=
GHOST_USER_ID=
